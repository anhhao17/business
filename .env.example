# Supabase credentials (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for metadata / absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin bootstrap email (the first user allowed into /admin)
ADMIN_EMAIL=you@example.com

# Optional: contact form destination (email shown to user / used in mailto)
CONTACT_EMAIL=orders@oceancatch.com
